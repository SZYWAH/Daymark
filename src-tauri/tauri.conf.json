{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Daymark",
  "version": "0.1.0-rc.7",
  "identifier": "com.szywah.daymark",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Daymark",
        "width": 1280,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 720,
        "visible": false,
        "backgroundColor": "#000000",
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' https: http: ws://127.0.0.1:* ws://localhost:*; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
