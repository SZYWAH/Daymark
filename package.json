{
  "name": "daymark",
  "private": true,
  "version": "0.1.0-rc.10",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.app.json --pretty false && tsc -p tsconfig.node.json --pretty false",
    "test": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "check": "pnpm typecheck && pnpm test && pnpm test:rust",
    "qa:fixtures": "node qa/generate-fixtures.mjs",
    "qa:data": "vitest run --config qa/vitest.config.ts",
    "qa:web": "node qa/run-playwright.mjs",
    "qa:mock-ai": "node qa/mock-ai.mjs",
    "qa:tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File qa/run-tauri-qa.ps1",
    "qa:tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -File qa/build-tauri-qa.ps1",
    "qa:installed:lifecycle": "pwsh -NoProfile -File qa/run-installed-lifecycle.ps1",
    "qa:installed:unit": "node --test qa/evaluate-startup-probe.selftest.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@vitejs/plugin-react": "^5.0.0",
    "animejs": "^4.2.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "^6.2.5",
    "jszip": "^3.10.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.10"
  }
}
